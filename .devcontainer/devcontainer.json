{
  "name": "${localWorkspaceFolderBasename}",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "PYTHON_VERSION": "3.13"
    }
  },
  "remoteUser": "vscode",
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
    "source=${localEnv:HOME}/.gitconfig,target=/tmp/.host-gitconfig,readonly,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.config/gcloud,target=/home/vscode/.config/gcloud,type=bind"
  ],
  "containerEnv": {
    "GOOGLE_CLOUD_PROJECT": "${localEnv:GOOGLE_CLOUD_PROJECT}",
    "GCP_PROJECT_ID": "${localEnv:GCP_PROJECT_ID}",
    "GCP_REGION": "${localEnv:GCP_REGION}",
    "APP_ENV": "development"
  },
  "postCreateCommand": "git config --global user.name \"$(git config -f /tmp/.host-gitconfig user.name)\" && git config --global user.email \"$(git config -f /tmp/.host-gitconfig user.email)\"; [ -f backend/pyproject.toml ] && (cd backend && uv sync) || echo 'No backend/pyproject.toml yet — skipping uv sync'",
  "forwardPorts": [3000, 8000, 5432, 9099],
  "portsAttributes": {
    "3000": { "label": "Dev server", "onAutoForward": "silent" },
    "8000": { "label": "ADK backend", "onAutoForward": "silent" },
    "5432": { "label": "Cloud SQL proxy (Postgres)", "onAutoForward": "silent" },
    "9099": { "label": "Firebase emulator (Auth)", "onAutoForward": "silent" }
  },
  "otherPortsAttributes": { "onAutoForward": "ignore" },
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.vscode-pull-request-github"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "terminal.integrated.defaultProfile.linux": "bash",
        "remote.autoForwardPorts": false,
        "remote.autoForwardPortsSource": "output"
      },
      "unwantedRecommendations": [
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
