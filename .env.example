# =============================================================================
# Agentic Learning App — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# In production, all values below are sourced from Secret Manager or Cloud Run
# environment variable bindings.
# =============================================================================

# --- GCP Core ----------------------------------------------------------------
GCP_PROJECT_ID=
GCP_REGION=us-central1

# --- Gemini / Vertex AI ------------------------------------------------------
# Application Default Credentials are used for Gemini API access.
# Run `gcloud auth application-default login` once for local dev.
# These tell the Google SDK which project and region to target.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# --- Content pipeline --------------------------------------------------------
# Set to a GCS bucket name to use GCS backend for pipeline I/O.
# Leave unset to use local filesystem (courses/linux-basics/pipeline/).
GCS_PIPELINE_BUCKET=

# --- Gemini context caching --------------------------------------------------
# Set to true to enable block-level Gemini context caching at startup.
# Disabled by default — only enable once user volume justifies it.
# See notes/simplification-plan-remove-rag-adk.md for details.
ENABLE_LESSON_CACHE=false

# --- Handoff provider ---------------------------------------------------------
# AI chat surface offered to learners after 3 unresolved help turns.
# Options: "google_ai_studio" | "disabled"
# Add new providers by implementing HandoffProvider in backend/handoff.py.
HANDOFF_PROVIDER=google_ai_studio

# --- Cloud Run (local testing against deployed backend) ----------------------
CLOUD_RUN_SERVICE_URL=

# --- Environment flag --------------------------------------------------------
# "development" | "production"
APP_ENV=development

# --- Google OAuth ------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=your-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
