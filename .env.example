# =============================================================================
# Agentic Learning App — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# In production, all values below are sourced from Secret Manager.
# =============================================================================

# --- GCP Core ----------------------------------------------------------------
GCP_PROJECT_ID=agentic-learning-app
GCP_REGION=us-central1

# --- Cloud SQL / PostgreSQL --------------------------------------------------
# Local dev: run Cloud SQL Auth Proxy and use localhost
# Cloud Run: uses private IP via VPC connector
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=learning_app
DB_USER=app_user

# Cloud SQL instance connection name (project:region:instance)
# Used by Cloud SQL Auth Proxy in local dev
DB_CONNECTION_NAME=agentic-learning-app:us-central1:learning-app-db

# DB_PASSWORD is NOT stored here. The backend config loader fetches it from
# Secret Manager at startup using Application Default Credentials.
# Local dev: run `gcloud auth application-default login` once — no password file needed.

# --- Vertex AI / ADK ---------------------------------------------------------
# ADK uses Application Default Credentials — run `gcloud auth application-default login`
# These tell the Google SDK which project and region to target
GOOGLE_CLOUD_PROJECT=agentic-learning-app
GOOGLE_CLOUD_LOCATION=us-central1

# Set to 1 to route Gemini calls through Vertex AI (required for production)
GOOGLE_GENAI_USE_VERTEXAI=1

# --- Cloud Run (local testing against deployed backend) ----------------------
# Set this after deploying the Cloud Run service in Phase 3
CLOUD_RUN_SERVICE_URL=https://your-service-url.run.app

# --- Environment flag --------------------------------------------------------
# "development" | "production"
APP_ENV=development
